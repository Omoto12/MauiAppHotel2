<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MauiAppHotel.Views.EventoResumo"
             Title="EventoResumo"
             NavigationPage.HasNavigationBar="False"
             BackgroundColor="{StaticResource Gray100}">

    <VerticalStackLayout VerticalOptions="CenterAndExpand">

        <Label Text="Resumo do Evento" 
               FontSize="50" FontFamily="CinzelSemiBold" 
               HorizontalTextAlignment="Center" 
               TextColor="{StaticResource Primary}"/>

        <Frame Padding="20">
            <Grid ColumnDefinitions="*, *" 
                  RowDefinitions="Auto, Auto, Auto, Auto, Auto, Auto" 
                  RowSpacing="12">

                <Label Grid.Row="0" Grid.Column="0" Text="Evento:" FontFamily="CinzelRegular"/>
                <Label Grid.Row="0" Grid.Column="1" Text="{Binding Nome}" TextColor="{StaticResource Primary}" HorizontalOptions="End" />

                <Label Grid.Row="1" Grid.Column="0" Text="Local:" FontFamily="CinzelRegular" />
                <Label Grid.Row="1" Grid.Column="1" Text="{Binding Local}" HorizontalOptions="End" />

                <Label Grid.Row="2" Grid.Column="0" Text="Participantes:" FontFamily="CinzelRegular" />
                <Label Grid.Row="2" Grid.Column="1" Text="{Binding NumeroParticipantes}" HorizontalOptions="End" />

                <Label Grid.Row="3" Grid.Column="0" Text="Duração Total:" FontFamily="CinzelRegular" />
                <Label Grid.Row="3" Grid.Column="1" Text="{Binding DuracaoDias, StringFormat='{0} dias'}" HorizontalOptions="End" TextColor="{StaticResource Primary}" />

                <Label Grid.Row="4" Grid.Column="0" Text="Custo por Pessoa:" FontFamily="CinzelRegular" />
                <Label Grid.Row="4" Grid.Column="1" Text="{Binding CustoPorParticipante, StringFormat='R$ {0:F2}'}" HorizontalOptions="End" />

                <Label Grid.Row="5" Grid.Column="0" Text="Custo Total:"FontFamily="CinzelRegular"FontAttributes="Bold" FontSize="Medium" />
                <Label Grid.Row="5" Grid.Column="1" Text="{Binding CustoTotal, StringFormat='R$ {0:F2}'}" FontFamily="CinzelRegular" TextColor="{StaticResource Primary}" HorizontalOptions="End" />

            </Grid>
        </Frame>

    </VerticalStackLayout>

</ContentPage>