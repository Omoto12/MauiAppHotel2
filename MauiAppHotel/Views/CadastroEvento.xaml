<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MauiAppHotel.Views.CadastroEvento"
             Title="CadastroEvento"
             NavigationPage.HasNavigationBar="False"
             BackgroundColor="{StaticResource Gray100}">

    <VerticalStackLayout>

        <Label Text="Novo Evento" 
               FontSize="50" 
               FontFamily="CinzelSemiBold"
               HorizontalTextAlignment="Center" 
               TextColor="{StaticResource Primary}"/>

        <Frame Padding="15">
            <VerticalStackLayout Spacing="10">
                <Label Text="Nome do Evento:" FontFamily="CinzelRegular" TextColor="{StaticResource Primary}"/>
                <Entry x:Name="txt_nome"/>

                <Label Text="Local do Evento:" FontFamily="CinzelRegular" TextColor="{StaticResource Primary}"/>
                <Entry x:Name="txt_local" />

                <Label Text="Número de Participantes:" FontFamily="CinzelRegular" TextColor="{StaticResource Primary}"/>
                <Entry x:Name="txt_participantes" Keyboard="Numeric"/>

                <Label Text="Custo por Participante:R$ " FontFamily="CinzelRegular" TextColor="{StaticResource Primary}"/>
                <Entry x:Name="txt_custo" Keyboard="Numeric" />
            </VerticalStackLayout>
        </Frame>

        <Frame Padding="15">
            <VerticalStackLayout Spacing="10">
                <Label Text="Data de Início:" FontFamily="CinzelRegular" TextColor="{StaticResource Primary}"/>
                <DatePicker x:Name="dtpck_inicio" Format="dd/MM/yyyy" DateSelected="Dtpck_inicio_DateSelected" />

                <Label Text="Data de Término:" FontFamily="CinzelRegular" TextColor="{StaticResource Primary}"/>
                <DatePicker x:Name="dtpck_termino" Format="dd/MM/yyyy" />
            </VerticalStackLayout>
        </Frame>

        <Button Text="Cadastrar Evento" Clicked="BtnCadastrar_Clicked"/>

    </VerticalStackLayout>

</ContentPage>